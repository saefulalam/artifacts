# ================================================================
#  .env.example — Artifact Visualizer v3 + WA Bridge
#  Copy ke .env dan isi sesuai environment kamu
# ================================================================

# ── PHP Server (artifact-visualizer.php) ──────────────────────

# DeepSeek API Key
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URL publik PHP server kamu (untuk generate viz link)
# Tanpa trailing slash!
VIZ_BASE_URL=https://yourserver.com/artifact-visualizer

# URL Vercel WA Bridge (setelah deploy wa-bridge/)
WA_BRIDGE_URL=https://your-wa-bridge.vercel.app

# Secret key antara PHP <-> Vercel bridge (GANTI sebelum production!)
BRIDGE_SECRET=ganti-ini-dengan-random-string-yang-panjang

# ── Vercel WA Bridge (wa-bridge/.env) ────────────────────────

# URL PHP server kamu
PHP_SERVER_URL=https://yourserver.com/artifact-visualizer.php

# Secret (harus SAMA dengan BRIDGE_SECRET di atas)
BRIDGE_SECRET=ganti-ini-dengan-random-string-yang-panjang

# ================================================================
#  CARA DEPLOY
# ================================================================
#
#  1. PHP Server:
#     - Upload artifact-visualizer.php ke web server PHP 8.1+
#     - Buat folder viz_cache/ dan beri permission write (chmod 755)
#     - Set env vars di atas (via .htaccess SetEnv atau panel hosting)
#     - Contoh .htaccess:
#         SetEnv DEEPSEEK_API_KEY sk-xxxx
#         SetEnv VIZ_BASE_URL https://yourserver.com
#         SetEnv WA_BRIDGE_URL https://your-bridge.vercel.app
#         SetEnv BRIDGE_SECRET your-secret
#
#  2. Vercel WA Bridge:
#     cd wa-bridge/
#     npm install
#     vercel login
#     vercel
#     # Set env vars di Vercel dashboard atau:
#     vercel env add PHP_SERVER_URL
#     vercel env add BRIDGE_SECRET
#     vercel --prod
#
#  3. Scan QR:
#     Buka: https://your-wa-bridge.vercel.app/api/qr
#     Scan dengan WhatsApp
#
#  4. Test via WA:
#     Kirim !help ke nomor bot
#
# ================================================================
#  CATATAN PENTING
# ================================================================
#
#  - Baileys adalah library WA unofficial yang GRATIS dan open source
#  - Tidak perlu WhatsApp Business API atau biaya apapun
#  - Sesi WA disimpan di /tmp di Vercel (reset tiap cold start)
#  - Untuk production, gunakan Vercel KV untuk persist sesi
#  - viz_cache/ otomatis menyimpan artifact HTML selama 30 hari
#  - MAX file cache: 500 rows per query (bisa diubah di PHP)
#
# ================================================================
